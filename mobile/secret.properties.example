# Copy this file to  secret.properties  (same folder) and paste your signing
# secret — the SAME hex value that's in your desktop secret.key. This unifies
# licensing: keys issued by your desktop License Console will activate the
# mobile app too.
#
# NEVER commit secret.properties — it's gitignored. Anyone with this value can
# forge license keys.
UMD_SECRET=paste_your_secret.key_hex_here

# Optional — a YouTube Data API v3 key for the Discover tab (trending / music /
# new releases). Get one free at console.cloud.google.com (enable "YouTube Data
# API v3" → create an API key). Leave blank to set it inside the app instead
# (Discover → "Set YouTube key"). A single bundled key shares one 10k-units/day
# quota across all users, so the app caches results for 6h.
YOUTUBE_API_KEY=
